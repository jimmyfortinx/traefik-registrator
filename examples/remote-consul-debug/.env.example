# Consul HTTP endpoint reachable from Docker (published API port)
CONSUL_HTTP_ADDR=http://10.1.2.10:18500

# Registrator identity controls owner-scoped cleanup
OWNER_ID=file-debug-local
SERVICE_ID_PREFIX=file-debug-

# Keep this on while debugging duplicate cleanup behavior
LOG_VERBOSE_CATALOG_CLEANUP=true

# Host path with your file-mode service definitions
FILE_SOURCE_PATH_HOST=./services.d
